			"contents": "<script setup>\nimport { computed, onBeforeUnmount, ref, watch } from 'vue'\n\nimport { formatCurrency } from '@/components/fields/FieldMoney.vue'\nimport { calculateItemTotals } from '@/utils/formatters.js'\n\nconst props = defineProps({\n  client: {\n    type: Object,\n    required: true,\n  },\n  supplier: {\n    type: Object,\n    required: true,\n  },\n  quote: {\n    type: Object,\n    required: true,\n  },\n  items: {\n    type: Array,\n    required: true,\n  },\n  services: {\n    type: Array,\n    default: () => [],\n  },\n  totals: {\n    type: Object,\n    required: true,\n  },\n  currency: {\n    type: String,\n    default: 'MXN',\n  },\n  includeVat: {\n    type: Boolean,\n    default: true,\n  },\n  brandPrimary: {\n    type: String,\n    default: '#111827',\n  },\n  brandSecondary: {\n    type: String,\n    default: '#f8fafc',\n  },\n  fontFamily: {\n    type: String,\n    default: 'roboto',\n  },\n  title: {\n    type: String,\n    default: '',\n  },\n  subtitle: {\n    type: String,\n    default: '',\n  },\n  logoFile: {\n    type: Object,\n    default: null,\n  },\n  priceNote: {\n    type: String,\n    default: '',\n  },\n  conditions: {\n    type: Array,\n    default: () => [],\n  },\n  extra: {\n    type: Object,\n    default: () => ({\n      paymentTerms: '',\n      notes: '',\n    }),\n  },\n})\n\nconst logoUrl = ref('')\n\nconst revokeLogo = () => {\n  if (logoUrl.value) {\n    URL.revokeObjectURL(logoUrl.value)\n    logoUrl.value = ''\n  }\n}\n\nconst updateLogo = (file) => {\n  revokeLogo()\n  if (file && file.type?.startsWith('image/')) {\n    logoUrl.value = URL.createObjectURL(file)\n  }\n}\n\nwatch(\n  () => props.logoFile,\n  (file) => updateLogo(file),\n  { immediate: true },\n)\n\nonBeforeUnmount(() => {\n  revokeLogo()\n})\n\nconst lineItems = computed(() =>\n  props.items.map((item) => {\n    const totals = calculateItemTotals({\n      quantity: item.quantity,\n      unitPrice: item.unitPrice,\n      discount: item.discount,\n      vatRate: props.includeVat ? item.vatRate : 0,\n    })\n\n    return {\n      name: item.name || 'Sin nombre',\n      description: item.description,\n      quantity: item.quantity || '1',\n      unitPrice: formatCurrency(Number.parseFloat(item.unitPrice) || 0, 'es-MX', props.currency),\n      amount: formatCurrency(totals.total, 'es-MX', props.currency),\n    }\n  }),\n)\n\nconst serviceLineItems = computed(() =>\n  props.services.map((group) => ({\n    title: group.title || 'Servicio',\n    items: (group.items || []).map((item) => {\n      const totals = calculateItemTotals({\n        quantity: item.quantity,\n        unitPrice: item.unitPrice,\n        discount: item.discount,\n        vatRate: props.includeVat ? item.vatRate : 0,\n      })\n\n      return {\n        description: item.description || 'Servicio',\n        quantity: item.quantity || '1',\n        unitPrice: formatCurrency(Number.parseFloat(item.unitPrice) || 0, 'es-MX', props.currency),\n        amount: formatCurrency(totals.total, 'es-MX', props.currency),\n      }\n    }),\n  })),\n)\n\nconst formattedTotals = computed(() => ({\n  subtotal: formatCurrency(props.totals.subtotal || 0, 'es-MX', props.currency),\n  discount: formatCurrency(props.totals.discount || 0, 'es-MX', props.currency),\n  vat: formatCurrency(props.totals.vat || 0, 'es-MX', props.currency),\n  total: formatCurrency(props.totals.total || 0, 'es-MX', props.currency),\n  vatPercent: Math.round((props.totals.vatRate || 0) * 100),\n}))\n\nconst supplierName = computed(\n  () =>\n    props.supplier.companyName || props.supplier.businessName || props.supplier.name || 'Empresa',\n)\n\nconst supplierAddress = computed(() => {\n  const parts = [props.supplier.street, props.supplier.neighborhood, props.supplier.fullAddress]\n  return parts.filter(Boolean).join(', ')\n})\n\nconst clientName = computed(() => props.client.businessName || props.client.name || 'Cliente')\n\nconst clientAddress = computed(() => {\n  const parts = [props.client.street, props.client.neighborhood, props.client.fullAddress]\n  return parts.filter(Boolean).join(', ')\n})\n\nconst paymentTerms = computed(() => props.extra?.paymentTerms?.toString().trim() || '')\nconst extraNotes = computed(() => props.extra?.notes?.toString().trim() || '')\nconst visibleConditions = computed(() => props.conditions.filter(Boolean))\nconst titleText = computed(() => props.title?.toString().trim() || '')\nconst subtitleText = computed(() => props.subtitle?.toString().trim() || '')\nconst hasHeaderText = computed(() => Boolean(titleText.value || subtitleText.value))\nconst quoteNumber = computed(() => props.quote?.number?.toString().trim() || '')\n\nconst fontFamilyMap = {\n  roboto: \"'Roboto', sans-serif\",\n  'pt-serif': \"'PT Serif', serif\",\n  'open-sans': \"'Open Sans', sans-serif\",\n  serif: 'serif',\n}\n\nconst hexToRgb = (value) => {\n  if (!value) {\n    return null\n  }\n\n  const raw = value.toString().trim().replace('#', '')\n  const normalized =\n    raw.length === 3\n      ? raw\n          .split('')\n          .map((char) => char + char)\n          .join('')\n      : raw\n\n  if (!/^[0-9a-fA-F]{6}$/.test(normalized)) {\n    return null\n  }\n\n  return {\n    r: Number.parseInt(normalized.slice(0, 2), 16),\n    g: Number.parseInt(normalized.slice(2, 4), 16),\n    b: Number.parseInt(normalized.slice(4, 6), 16),\n  }\n}\n\nconst isDarkColor = (value) => {\n  const rgb = hexToRgb(value)\n  if (!rgb) {\n    return false\n  }\n\n  const luminance = (0.2126 * rgb.r + 0.7152 * rgb.g + 0.0722 * rgb.b) / 255\n  return luminance < 0.55\n}\n\nconst previewStyle = computed(() => ({\n  '--preview-font': fontFamilyMap[props.fontFamily] || \"'Roboto', sans-serif\",\n  '--preview-primary': props.brandPrimary || '#111827',\n  '--preview-line': props.brandSecondary || '#e2e8f0',\n  '--preview-header-text': isDarkColor(props.brandPrimary) ? '#f8fafc' : '#111827',\n}))\n</script>\n\n<template>\n  <section class=\"quote-preview\" :style=